- Direct: postgresql://postgres:<pwd>@db.dcilltzgegqsrgatskhz.supabase.co:5432/postgres
- Session pooler: postgresql://postgres.dcilltzgegqsrgatskhz:<pwd>@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres

